{
  "name": "@qorechain/wallet-adapter",
  "version": "0.1.5",
  "description": "Drop-in adapter to add QoreChain to any Cosmos wallet (Keplr, Leap, Cosmostation, …) and sign its PQC-required transactions. The wallet signs an ordinary SIGN_MODE_DIRECT SignDoc; the adapter layers a standard FIPS-204 ML-DSA-87 hybrid signature into the tx body, so no wallet code changes are needed.",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "qorechain",
    "keplr",
    "cosmos",
    "wallet",
    "post-quantum",
    "ml-dsa",
    "pqc",
    "dilithium"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@qorechain/pqc": "^0.1.1",
    "cosmjs-types": "^0.9.0",
    "@cosmjs/crypto": "^0.32.0",
    "@cosmjs/encoding": "^0.32.0"
  },
  "devDependencies": {
    "@noble/post-quantum": "^0.6.1"
  },
  "peerDependencies": {
    "@cosmjs/proto-signing": "^0.32.0",
    "@cosmjs/stargate": "^0.32.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qorechain/qorechain-wallet-adapter.git"
  },
  "homepage": "https://github.com/qorechain/qorechain-wallet-adapter#readme",
  "bugs": {
    "url": "https://github.com/qorechain/qorechain-wallet-adapter/issues"
  }
}
